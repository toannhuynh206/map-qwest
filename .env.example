# Supabase - get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database - get from Supabase project settings > Database > Connection string
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Daily Puzzle — set this to your actual go-live date on Digital Ocean.
# The 30-day puzzle cycle starts from this date (UTC midnight).
# Format: YYYY-MM-DD
# Example: NEXT_PUBLIC_PUZZLE_LAUNCH_DATE=2024-06-01
NEXT_PUBLIC_PUZZLE_LAUNCH_DATE=YYYY-MM-DD
